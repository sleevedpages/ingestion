# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/sleevedpages

# Optional: override the TCGCSV base URL (default: https://tcgcsv.com)
TCGCSV_BASE_URL=https://tcgcsv.com

# Optional: log verbosity — debug | info | warn | error (default: info)
LOG_LEVEL=info

# Optional: fetch and transform data but skip all DB writes (default: false)
DRY_RUN=false

# Optional: override the cron schedule (default: 0 6 * * * = 6am UTC daily)
CRON_SCHEDULE=0 6 * * *

# Optional: max sets to process per TCG per run (default: no limit).
# Use this to stage the initial backfill — Pokemon and Magic each have 200+ sets
# which together approach the 10,000 req/day TCGCSV limit.
# Example: BACKFILL_LIMIT=50 processes 50 sets per TCG (200 sets total across 4 TCGs).
# Unset or leave blank once the initial load is complete.
BACKFILL_LIMIT=

# Optional: bypass the "TCGCSV unchanged since last sync" early-exit check (default: false).
# Required when running multiple backfill passes on the same day before TCGCSV refreshes.
FORCE_SYNC=false
