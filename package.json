{
  "name": "sleevedpages-ingestion",
  "version": "1.0.0",
  "description": "Daily card data ingestion from TCGCSV into the SleevedPages D1 database",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply sleevedpagesdb --local",
    "migrate:remote": "wrangler d1 migrations apply sleevedpagesdb --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5",
    "wrangler": "^4.103.0"
  }
}
